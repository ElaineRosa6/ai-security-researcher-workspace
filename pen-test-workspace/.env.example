# ============================================================
# AI Security Researcher Workspace - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to version control!
# ============================================================

# ---- Path Configuration ----
WORKSPACE_ROOT=/workspace/pen-test-workspace
TOOLS_PATH=${WORKSPACE_ROOT}/shared/tools
WORDLISTS_PATH=${WORKSPACE_ROOT}/shared/wordlists
OUTPUT_PATH=${WORKSPACE_ROOT}/output
COMPLIANCE_PATH=${WORKSPACE_ROOT}/compliance
PROXY_CONFIG_PATH=${WORKSPACE_ROOT}/config/proxy
AGENT_PATH=${WORKSPACE_ROOT}/agent
SKILLS_PATH=${WORKSPACE_ROOT}/ai-agent/skills
HARNESS_PATH=${WORKSPACE_ROOT}/ai-agent/harness
WORKFLOWS_PATH=${WORKSPACE_ROOT}/ai-agent/workflows

# ---- API Keys ----
VIRUSTOTAL_API_KEY=your_api_key_here
SHODAN_API_KEY=your_api_key_here
CENSYS_API_ID=your_api_id_here
CENSYS_API_SECRET=your_api_secret_here
OPENAI_API_KEY=your_openai_api_key_here

# ---- Database Configuration ----
DATABASE_URL=sqlite://${WORKSPACE_ROOT}/workspace-data/pentest.db

# ---- Logging Configuration ----
LOG_LEVEL=INFO
LOG_FILE=${OUTPUT_PATH}/logs/workspace.log

# ---- Proxy Configuration ----
TOR_ENABLED=true
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
PROXYCHAINS_ENABLED=true
PROXYCHAINS_CONFIG=${PROXY_CONFIG_PATH}/proxychains.conf

# ---- Compliance Configuration ----
RECORDING_ENABLED=true
SCREEN_RECORDING_ENABLED=true
TERMINAL_RECORDING_ENABLED=true
NETWORK_CAPTURE_ENABLED=false
AUDIT_LOGGING_ENABLED=true
EVIDENCE_SIGNING_ENABLED=true
ENCRYPTION_ENABLED=true

# ---- GPG Configuration ----
GPG_KEY_ID=your_key_id
GPG_KEY_PATH=/path/to/private/key

# ---- Session Configuration ----
SESSION_AUTO_START=true
SESSION_AUTO_ARCHIVE=true
SESSION_RETENTION_DAYS=90

# ---- Python Environment ----
PYTHON=python3
PYTHON_PATH=/usr/bin/python3

# ---- Timeout Settings (seconds) ----
TOOL_TIMEOUT=300
SCAN_TIMEOUT=3600
EXPLOIT_TIMEOUT=60
